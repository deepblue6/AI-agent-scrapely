# =============================================================================
# AI Setter Agent — Environment Variables
# =============================================================================
# If running locally: copy this file to .env and fill in your values
#   cp .env.example .env
#
# If deploying to Railway: add these in the Variables tab instead
# =============================================================================

# Anthropic (Claude) API key — used for generating AI replies
# Get yours at: https://console.anthropic.com
# IMPORTANT: You must add a payment method in Settings > Billing before the key will work
ANTHROPIC_API_KEY=sk-ant-...

# Scrapely API key — used for fetching conversations, sending DMs, updating CRM
# Find this in your Scrapely dashboard under Settings > API
SCRAPELY_API_KEY=your-scrapely-api-key

# Your booking/calendar link — this gets dropped into conversations when pushing for a call
CALENDAR_LINK=https://calendly.com/your-link

# Webhook authentication — Scrapely sends this header with every webhook request
# Find it in: Scrapely Dashboard → Settings → Global Webhook → your webhook's X-Webhook-Key
WEBHOOK_SECRETS=your-webhook-secret-here
