# Anthropic (Claude) API key — used for generating AI replies
ANTHROPIC_API_KEY=sk-ant-...

# Scrapely API — used for fetching conversations, sending DMs, updating CRM
SCRAPELY_API_KEY=your-scrapely-api-key
SCRAPELY_API_BASE=https://app.scrapely.co/api/v1

# Webhook authentication — comma-separated list of valid keys
# Scrapely sends this in the x-webhook-key header
WEBHOOK_SECRETS=secret1,secret2

# Server port (default: 9002)
PORT=9002

# Optional: proxy for outbound requests (useful on Hetzner to avoid ECONNRESET)
# OUTBOUND_PROXY=1.2.3.4:8080
# OUTBOUND_PROXY_AUTH=user:pass
